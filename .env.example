# --- PostgreSQL (generate password locally) ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_PASSWORD
POSTGRES_DB=n8n

# --- n8n core secrets (generate locally) ---
N8N_ENCRYPTION_KEY=REPLACE_WITH_LONG_RANDOM_64_PLUS_CHAR_SECRET
N8N_USER_MANAGEMENT_JWT_SECRET=REPLACE_WITH_ANOTHER_LONG_RANDOM_64_PLUS_CHAR_SECRET

# --- n8n runtime / URLs (set to your domain) ---
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
WEBHOOK_URL=https://n8n.gkcircle.com/
N8N_EDITOR_BASE_URL=https://n8n.gkcircle.com/
N8N_HOST=n8n.gkcircle.com
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_PROXY_HOPS=1
NODE_ENV=production
GENERIC_TIMEZONE=Asia/Kolkata

# --- Cloudflared / Browserless tokens (copy from websites) ---
CLOUDFLARE_TOKEN=REPLACE_WITH_YOUR_REAL_CLOUDFLARE_TUNNEL_TOKEN
BROWSERLESS_TOKEN=REPLACE_WITH_A_LONG_RANDOM_BROWSERLESS_TOKEN_OR_PROVIDER_TOKEN

# --- MinIO (set user, generate password locally) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_WITH_LONG_RANDOM_MINIO_PASSWORD

# --- Internal service URLs (keep as-is for Docker) ---
OLLAMA_HOST=http://ollama:11434
CRAWL4AI_HOST=http://crawl4ai:11235
BROWSERLESS_URL=http://browserless:3000
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=minio
MINIO_PORT=9000

# --- Proxy (only if you actually run squid) ---
HTTP_PROXY=http://squid:3128
HTTPS_PROXY=http://squid:3128
NO_PROXY=localhost,127.0.0.1,n8n,postgres,ollama,qdrant,crawl4ai,browserless,minio,squid
